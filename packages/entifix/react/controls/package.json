{
  "name": "@r10c/entifix-react-controls",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.esm.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.esm.d.ts",
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@r10c/entifix-ts-core": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "effect": "3.22.0"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@r10c/source": "./src/index.ts",
      "types": "./dist/index.esm.d.ts",
      "import": "./dist/index.esm.js",
      "default": "./dist/index.esm.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "devDependencies": {
    "@r10c/entifix-style": "workspace:*",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/addon-themes": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "storybook": "^10.5.3"
  },
  "nx": {
    "targets": {
      "storybook": {
        "command": "storybook dev -p 6006 --no-open",
        "options": {
          "cwd": "{projectRoot}"
        }
      },
      "build-storybook": {
        "command": "storybook build",
        "options": {
          "cwd": "{projectRoot}"
        },
        "outputs": [
          "{projectRoot}/storybook-static"
        ]
      }
    }
  }
}
