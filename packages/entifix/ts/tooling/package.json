{
  "name": "@r10c/entifix-ts-tooling",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@r10c/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./logging": {
      "@r10c/source": "./src/logging/index.ts",
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.js",
      "default": "./dist/logging/index.js"
    },
    "./tracking": {
      "@r10c/source": "./src/tracking/index.ts",
      "types": "./dist/tracking/index.d.ts",
      "import": "./dist/tracking/index.js",
      "default": "./dist/tracking/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "nx": {
    "sourceRoot": "packages/entifix/ts/tooling/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "packages/entifix/ts/tooling/dist",
          "main": "packages/entifix/ts/tooling/src/index.ts",
          "tsConfig": "packages/entifix/ts/tooling/tsconfig.lib.json",
          "skipTypeCheck": true,
          "stripLeadingPaths": true
        }
      }
    }
  },
  "dependencies": {
    "@swc/helpers": "0.5.23",
    "@opentelemetry/api": "1.9.1"
  }
}
