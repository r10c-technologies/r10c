{
  "name": "@r10c/business-ts-authn",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@r10c/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "@r10c/source": "./src/contracts.ts",
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js",
      "default": "./dist/contracts.js"
    }
  },
  "nx": {
    "sourceRoot": "packages/business/ts/authn/src",
    "targets": {
      "build": {
        "executor": "@nx/js:swc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "packages/business/ts/authn/dist",
          "main": "packages/business/ts/authn/src/index.ts",
          "tsConfig": "packages/business/ts/authn/tsconfig.lib.json",
          "skipTypeCheck": true,
          "stripLeadingPaths": true
        }
      }
    }
  },
  "dependencies": {
    "@swc/helpers": "0.5.23",
    "@r10c/entifix-ts-core": "workspace:*",
    "effect": "3.21.4"
  }
}
