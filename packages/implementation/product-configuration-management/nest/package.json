{
  "name": "@r10c/implementation-product-configuration-management-nest",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@r10c/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "tslib": "2.8.1",
    "@nestjs/common": "11.1.27"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "dist/packages/implementation/product-configuration-management/nest",
          "tsConfig": "packages/implementation/product-configuration-management/nest/tsconfig.lib.json",
          "packageJson": "packages/implementation/product-configuration-management/nest/package.json",
          "main": "packages/implementation/product-configuration-management/nest/src/index.ts",
          "assets": [
            "packages/implementation/product-configuration-management/nest/*.md"
          ]
        }
      }
    }
  }
}