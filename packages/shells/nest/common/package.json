{
  "name": "@r10c/shells-nest-common",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@r10c/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "tslib": "2.8.1",
    "@nestjs/common": "11.1.27"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "dist/packages/shells/nest/common",
          "tsConfig": "packages/shells/nest/common/tsconfig.lib.json",
          "packageJson": "packages/shells/nest/common/package.json",
          "main": "packages/shells/nest/common/src/index.ts",
          "assets": [
            "packages/shells/nest/common/*.md"
          ]
        }
      }
    }
  }
}