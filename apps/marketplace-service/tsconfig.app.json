{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "target": "es2022",
    // Effect-native shell: stage-3 decorators, no legacy Nest DI. See
    // apps/auth-service for the rationale (single decorator mode across the
    // whole bundle; entities importable natively).
    "experimentalDecorators": false,
    "importHelpers": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "out-tsc",
    "dist",
    "vitest.config.mts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "references": [
    {
      "path": "../../packages/shells/effect/service/tsconfig.lib.json"
    }
  ]
}
