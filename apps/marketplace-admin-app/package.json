{
  "name": "@r10c/marketplace-admin-app",
  "version": "0.0.1",
  "private": true,
  "dependencies": {
    "@r10c/entifix-react-controls": "workspace:*",
    "@r10c/entifix-style": "workspace:*",
    "@r10c/shells-next-common": "workspace:*",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "nx": {
    "targets": {
      "dev": {
        "executor": "nx:run-commands",
        "options": {
          "command": "next dev -p 3001",
          "cwd": "apps/marketplace-admin-app"
        },
        "dependsOn": [
          {
            "projects": [
              "@r10c/marketplace-admin-service",
              "@r10c/auth-app",
              "@r10c/config-service"
            ],
            "target": "dev"
          }
        ]
      },
      "start": {
        "executor": "nx:run-commands",
        "options": {
          "command": "next start -p 3001",
          "cwd": "apps/marketplace-admin-app"
        }
      },
      "dev-w-deps": {
        "executor": "nx:run-commands",
        "options": {
          "command": "pnpm nx run-many --projects=marketplace-admin-app --target=watch-deps,dev --parallel"
        }
      }
    }
  }
}
