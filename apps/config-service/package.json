{
  "name": "@r10c/config-service",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "tags": [
      "layer:app",
      "scope:config"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--config-node-env=production"
          ],
          "cwd": "apps/config-service"
        },
        "configurations": {
          "development": {
            "args": [
              "--config-node-env=development"
            ]
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/config-service/dist/package.json",
          "{workspaceRoot}/apps/config-service/dist/pnpm-lock.yaml"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/config-service/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "ensure-infra": {
        "executor": "nx:run-commands",
        "cache": false,
        "options": {
          "command": "bash infra/local/ensure.sh"
        }
      },
      "dev": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build",
          "ensure-infra"
        ],
        "options": {
          "buildTarget": "@r10c/config-service:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@r10c/config-service:build:development"
          },
          "production": {
            "buildTarget": "@r10c/config-service:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  },
  "dependencies": {
    "@r10c/entifix-ts-core": "workspace:*",
    "@r10c/shells-effect-service": "workspace:*",
    "@effect/platform": "0.97.0",
    "@effect/platform-node": "0.108.0",
    "@effect/sql": "0.52.0",
    "@effect/sql-pg": "0.53.0",
    "dotenv": "^17.4.2",
    "effect": "3.22.0",
    "tslib": "2.8.1"
  }
}
