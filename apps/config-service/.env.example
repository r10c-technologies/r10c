# Centralized configuration for the marketplace fleet.
#
# Variable names encode three segments separated by double underscores:
#   SERVICE__GROUP__KEY=value
#
#   SERVICE  the consuming service (path param of GET /api/config/:service)
#   GROUP    the configuration group (e.g. "uri")
#   KEY      the configuration key (may contain dots/hyphens)
#
# A request for a service returns only its variables, grouped into
# ConfigurationPlain: { [group]: [{ key, value }] }.

# --- marketplace-admin-app → marketplace-admin-service (3101) ---
marketplace-admin-app__uri__marketplace-admin-service-domain=http://localhost:3101/api

# --- marketplace-app → marketplace-service (3100) ---
marketplace-app__uri__marketplace-service-domain=http://localhost:3100/api

# --- auth-app → auth-service (3102) ---
auth-app__uri__auth-service-domain=http://localhost:3102/api
