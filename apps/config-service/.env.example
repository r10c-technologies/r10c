# config-service bootstrap (LOCAL DEV ONLY defaults).
#
# Configuration data now lives in Postgres (the `configuration` table), migrated
# and seeded on first boot. The only thing config-service needs from the
# environment is how to reach Postgres.

# Postgres connection string. Default points at the infra/local minikube
# NodePort (30432). Override in production.
CONFIG_PG_URL=postgres://postgres:postgres@127.0.0.1:30432/postgres
