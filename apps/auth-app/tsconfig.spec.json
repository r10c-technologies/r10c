{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/vitest",
    "jsx": "preserve",
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "vite/client",
      "node"
    ]
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/**/*.d.ts",
    "specs/**/*.spec.ts",
    "specs/**/*.spec.tsx"
  ],
  "references": [
    {
      "path": "./tsconfig.json"
    }
  ]
}
