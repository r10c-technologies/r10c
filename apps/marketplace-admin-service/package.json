{
  "name": "@r10c/marketplace-admin-service",
  "version": "0.0.1",
  "private": true,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@r10c/source": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--config-node-env=production"
          ],
          "cwd": "apps/marketplace-admin-service"
        },
        "configurations": {
          "development": {
            "args": [
              "--config-node-env=development"
            ]
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/marketplace-admin-service/dist/package.json",
          "{workspaceRoot}/apps/marketplace-admin-service/dist/pnpm-lock.yaml"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/marketplace-admin-service/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "ensure-infra": {
        "executor": "nx:run-commands",
        "cache": false,
        "options": {
          "command": "bash infra/local/ensure.sh"
        }
      },
      "dev": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build",
          "ensure-infra",
          {
            "projects": "@r10c/config-service",
            "target": "dev"
          }
        ],
        "options": {
          "buildTarget": "@r10c/marketplace-admin-service:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@r10c/marketplace-admin-service:build:development"
          },
          "production": {
            "buildTarget": "@r10c/marketplace-admin-service:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  },
  "dependencies": {
    "@r10c/business-ts-authn": "workspace:*",
    "@r10c/business-ts-product-configuration-management": "workspace:*",
    "@r10c/entifix-ts-business": "workspace:*",
    "@r10c/entifix-ts-core": "workspace:*",
    "@r10c/entifix-ts-jwt-client": "workspace:*",
    "@r10c/entifix-ts-mongo-client": "workspace:*",
    "@r10c/entifix-ts-redis-client": "workspace:*",
    "@r10c/entifix-ts-amqp-client": "workspace:*",
    "@r10c/entifix-transactions": "workspace:*",
    "@r10c/shells-effect-service": "workspace:*",
    "@effect/platform": "0.97.0",
    "@effect/platform-node": "0.108.0",
    "effect": "3.22.0",
    "jose": "6.2.4",
    "mongodb": "7.5.0",
    "ioredis": "5.11.1",
    "amqplib": "2.0.1",
    "tslib": "2.8.1"
  }
}
