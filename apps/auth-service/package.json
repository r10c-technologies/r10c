{
  "name": "@r10c/auth-service",
  "version": "0.0.1",
  "private": true,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@r10c/source": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "nx": {
    "targets": {
      "ensure-infra": {
        "executor": "nx:run-commands",
        "cache": false,
        "options": {
          "command": "bash infra/local/ensure.sh"
        }
      },
      "dev": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build",
          "ensure-infra",
          {
            "projects": "@r10c/config-service",
            "target": "dev"
          }
        ],
        "options": {
          "buildTarget": "@r10c/auth-service:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@r10c/auth-service:build:development"
          },
          "production": {
            "buildTarget": "@r10c/auth-service:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  },
  "dependencies": {
    "@r10c/business-ts-authn": "workspace:*",
    "@r10c/entifix-ts-business": "workspace:*",
    "@r10c/entifix-ts-core": "workspace:*",
    "@r10c/entifix-ts-mongo-client": "workspace:*",
    "@r10c/shells-effect-service": "workspace:*",
    "@effect/platform": "0.97.0",
    "@effect/platform-node": "0.108.0",
    "effect": "3.22.0",
    "mongodb": "7.5.0",
    "tslib": "2.8.1"
  }
}
