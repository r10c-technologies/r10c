{
  "name": "@r10c/auth-service",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@r10c/auth-service:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@r10c/auth-service:build:development"
          },
          "production": {
            "buildTarget": "@r10c/auth-service:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  },
  "dependencies": {
    "@r10c/business-ts-authn": "workspace:*",
    "@r10c/entifix-ts-core": "workspace:*",
    "@r10c/shells-effect-service": "workspace:*",
    "@effect/platform": "0.96.2",
    "@effect/platform-node": "0.107.0",
    "effect": "3.21.4",
    "tslib": "2.8.1"
  }
}
