{
  "name": "@r10c/marketplace-service-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@r10c/marketplace-service"
    ],
    "targets": {
      "e2e": {
        "executor": "nx:run-commands",
        "outputs": [
          "{projectRoot}/test-output/vitest"
        ],
        "options": {
          "command": "vitest run --config vitest.config.mts --passWithNoTests",
          "cwd": "apps/marketplace-service-e2e"
        },
        "dependsOn": [
          "@r10c/marketplace-service:build",
          "@r10c/marketplace-service:dev"
        ]
      }
    }
  }
}
