# LOCAL DEV ONLY — do not reuse these credentials anywhere real.
#
# ZITADEL_MASTERKEY is NOT listed here — apply.sh generates a random 32-char
# key into the real .env on first run. Never commit the master key.
#
# Admin connection password — must match postgres/.env POSTGRES_PASSWORD.
ZITADEL_DATABASE_POSTGRES_ADMIN_PASSWORD=postgres
# Password Zitadel sets for the app db user it creates on init.
ZITADEL_DATABASE_POSTGRES_USER_PASSWORD=zitadel
# First-instance console admin login (username is set in the deployment).
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORD=Password1!
